# ChronoSight Frontend — environment variables
# Copy this file to .env and fill in values as needed.

# Backend URL used by the Vite dev server proxy.
# Change this if your backend runs on a different host or port.
BACKEND_URL=http://localhost:8000

# API base URL baked into the production build.
# Leave empty when frontend and backend share the same domain (e.g. behind a reverse proxy).
# Set to the full backend origin (e.g. https://api.example.com) for cross-domain deployments.
VITE_API_BASE_URL=
