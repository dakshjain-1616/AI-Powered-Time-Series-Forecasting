# ChronoSight Backend — environment variables
# Copy this file to .env and fill in values as needed.

# Host / port for the FastAPI server (uvicorn)
HOST=0.0.0.0
PORT=8000

# HuggingFace model hub cache directory (optional)
# Defaults to ~/.cache/huggingface/
# HF_HOME=/path/to/cache

# Set to "true" to force CPU inference even when a GPU is available
# FORCE_CPU=false
